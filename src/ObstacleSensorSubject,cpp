#include "rvc/ObstacleSensorSubject.hpp"

namespace rvc {
ObstacleSensorSubject::ObstacleSensorSubject(std::unique_ptr<IObstacleSensor> sensor,
                                             bool useInterrupt)
    : sensor_{std::move(sensor)}, useInterrupt_{useInterrupt} {
    if (!useInterrupt_) {
        pollingTimer_.setDuration(100); // Poll every 100 ms
    }
}

void ObstacleSensorSubject::attach(ISensorObserver* obs) {
    observers_.push_back(obs);
}

void ObstacleSensorSubject::detach(ISensorObserver* obs) {
    observers_.remove(obs);
}

void ObstacleSensorSubject::notify() {
    if (!sensor_) {
        return;
    }
    bool front = sensor_->isFrontDetected();
    bool left = sensor_->isLeftDetected();
    bool right = sensor_->isRightDetected();

    for (auto* obs : observers_) {
        obs->onObstacleDetected(front, left, right);
    }
}

void ObstacleSensorSubject::poll() {
    if (!useInterrupt_ && pollingTimer_.isExpired()) {
        pollingTimer_.reset();
        notify();
    }
}

// cppcheck-suppress unusedFunction
void ObstacleSensorSubject::onInterrupt() {
    if (useInterrupt_) {
        notify();
    }
}

} // namespace rvc